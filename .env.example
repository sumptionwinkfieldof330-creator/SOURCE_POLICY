# Thời gian chờ 2FA sau nhập sai: lần 1→2 = 15s, lần 2→3 = 30s (cấu hình trong components/modals/TwoFactorModal.tsx)

# Telegram — chỉ dùng giá trị thật trong .env local, không commit .env
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tùy chọn: nếu dùng kênh thông báo khác (cùng helper)
NOTIFICATION_TOKEN=
NOTIFICATION_CHAT=

WEBHOOK_URL=

# Khóa AES phải khớp client (NEXT_PUBLIC_*) và server; đặt chuỗi dài ngẫu nhiên, không dùng mặc định trên production
NEXT_PUBLIC_AES_SECRET_KEY=

NEXT_PUBLIC_NOTIFICATION_ENABLED=true

# URL công khai của site (OG image, metadata). Vercel tự dùng VERCEL_URL nếu bỏ trống.
NEXT_PUBLIC_SITE_URL=
